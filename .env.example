# .env.example
# Copy this to .env and fill in your keys
# cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────

# Anthropic API key — used for LLM-as-judge, eval agent, span scoring
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key — used for embeddings (ChromaDB semantic search)
# Get yours at https://platform.openai.com/api-keys
# Note: only embeddings use OpenAI — all LLM calls use Anthropic
OPENAI_API_KEY=sk-your-key-here


# ── Database ──────────────────────────────────────────────────────────────

# Leave blank to use SQLite (easiest for local dev without Docker)
# Set to postgresql://... when running with docker-compose
DATABASE_URL=

# Only needed when running with docker-compose
POSTGRES_PASSWORD=TraceMind_dev


# ── Security ─────────────────────────────────────────────────────────────

# Random string used for internal signing — change in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_in_production


# ── Optional ─────────────────────────────────────────────────────────────

# Redis URL — used for caching in production (optional, app works without it)
# REDIS_URL=redis://localhost:6379

# Set to "production" to disable debug logging and SQL echo
# ENVIRONMENT=development

# Webhook URL for regression alerts (per-project, set via API or dashboard)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/your-webhook